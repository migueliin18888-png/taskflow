# Puerto donde correrá el servidor
PORT=4000

# Cadena de conexión a MongoDB (local o Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/taskflow

# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET=cambia_este_valor_por_un_secreto_seguro
JWT_EXPIRES_IN=1d

# Origen permitido para CORS (el frontend)
CLIENT_ORIGIN=http://localhost:5173
